# =============================================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Database (required) ---
# For local dev with docker-compose, this works out of the box:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/longevity

# --- API Authentication (required) ---
# Shared secret between backend and frontend. Pick any string for local dev.
# Must match BACKEND_API_KEY in the frontend .env.local
API_KEY=change-me-local-dev-key


# --- LLM Provider (required) ---
# "fake" = deterministic stubs, no network (for dev/tests)
# "gemini" = real Gemini API (needs GEMINI_API_KEY or GCP credentials)
LLM_PROVIDER=fake

# --- Gemini API Key (required when LLM_PROVIDER=gemini) ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Vertex AI (alternative to API key, leave blank if using GEMINI_API_KEY) ---
# GCP_PROJECT=ai-hack26ham-445
# GCP_LOCATION=europe-west3

# --- Photo Storage ---
# "local" = saves to ./var/photos (default for dev)
# "gcs" = Google Cloud Storage (needs PHOTO_GCS_BUCKET)
PHOTO_STORAGE_BACKEND=local
# PHOTO_GCS_BUCKET=

# --- Logging ---
LOG_LEVEL=DEBUG
APP_ENV=local
