# Copy this file to .env and fill in the values before running locally.
# .env is git-ignored — never commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose): postgresql+asyncpg://postgres:postgres@localhost:5432/longevity
# Cloud Run: set via --set-secrets / Secret Manager mount
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/longevity

# ── API Authentication ────────────────────────────────────────────────────────
# Shared secret validated by the X-API-Key header on every non-health route.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-before-running

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Application environment ───────────────────────────────────────────────────
# One of: local, staging, production
APP_ENV=local
